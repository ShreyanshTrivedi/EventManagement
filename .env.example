# Copy this file to .env and adjust values as needed.

# ─── Ports ──────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8080
MYSQL_PORT=3306

# ─── MySQL ──────────────────────────────────────────
MYSQL_DATABASE=campus_events
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_password_here

# ─── Spring Boot Datasource ────────────────────────
# Inside Docker use host "mysql"; outside Docker use "localhost"
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/campus_events?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_strong_password_here

# ─── JPA ────────────────────────────────────────────
# Use "update" for dev, "validate" for production
JPA_DDL_AUTO=update

# ─── JWT ────────────────────────────────────────────
APP_SECURITY_JWTSECRET=CHANGE_ME_generate_a_random_64_char_string
JWT_EXPIRATION_MS=3600000

# ─── CORS ───────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Email (SMTP) ──────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ─── Twilio (SMS notifications) ───────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Frontend ──────────────────────────────────────
# URL the browser uses to reach the backend API
VITE_API_BASE_URL=http://localhost:8080
